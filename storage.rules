rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures:
    // - Allow anyone to read (e.g., to display avatars).
    // - Allow authenticated users to write only to their own profile picture path.
    match /profile-pictures/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Service request attachments:
    // - Allow authenticated users to write only to their own attachments path.
    // - Allow authenticated users to read attachments.
    //   (Consider making this more restrictive if needed, e.g., only owner or admin can read)
    match /service-request-attachments/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny all other paths for security.
    // Remove this if you have other paths that need to be public or have different rules.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
