rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures:
    // - Allow public read
    // - Allow authenticated users to write only to their own profile picture path
    match /profile-pictures/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Service request attachments:
    // - Allow authenticated users to write only to their own attachments path
    // - Allow authenticated users to read (consider restricting further if needed, e.g., only admins or owner)
    match /service-request-attachments/{userId}/{fileName} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other reads and writes by default for security
    match /{allPaths=**} {
      allow read: if false; 
      allow write: if false; 
    }
  }
}
