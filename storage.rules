
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match any file in the service-request-attachments directory
    match /service-request-attachments/{userId}/{allPaths=**} {
      // Allow write (upload) only if the requesting user's ID matches the {userId} in the path
      // and the file size is less than 5MB (5 * 1024 * 1024 bytes)
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;

      // Allow read for any authenticated user.
      // You might want to restrict this further, e.g., only the uploader or admins.
      // For download URLs to work easily for the client and admin, this is a common starting point.
      allow read: if request.auth != null;
    }

    // Optional: Default deny all other paths if not explicitly matched
    // match /{allPaths=**} {
    //   allow read, write: if false;
    // }
  }
}
