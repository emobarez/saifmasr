
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Files for service requests
    // Path: service-request-attachments/{userId}/{filename}
    match /service-request-attachments/{userId}/{allPaths=**} {
      // Allow write (upload) only if the user is authenticated and their UID matches the {userId} in the path.
      // This ensures users can only upload to their own "folder".
      allow write: if request.auth != null && request.auth.uid == userId;

      // Allow read if the user is authenticated.
      // The actual access to the download URL should be controlled by your Firestore security rules
      // (e.g., only the client who owns the request or an admin can see the request document containing the URL).
      // Unpredictable URLs provide a layer of security by obscurity.
      allow read: if request.auth != null;
    }

    // Default deny for all other paths not explicitly matched
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
