
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin role 
    // IMPORTANT: For production, use a more secure method like Firebase Auth custom claims 
    // or a roles collection in Firestore.
    function isAdmin() {
      // Example: Check for specific admin email(s)
      return request.auth.token.email == "admin@saifmasr.com" || request.auth.token.email == "admin@example.com";
    }

    // System settings: Publicly readable, admin writable
    match /systemSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services: Publicly readable, admin writable
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Clients: Admin managed. 
    // Client-specific data is typically in other collections linked by clientId.
    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    // Employees: Admin managed
    match /employees/{employeeId} {
      allow read, write: if isAdmin();
    }
    
    // Service Requests:
    // Clients can create for themselves, and read/update/delete their own.
    // Admins can manage all.
    match /serviceRequests/{requestId} {
      allow read: if isAdmin() || (request.auth.uid == resource.data.clientId);
      allow create: if request.auth.uid == request.resource.data.clientId; // Ensure client creates for themselves
      allow update: if isAdmin() || (request.auth.uid == resource.data.clientId); 
      allow delete: if isAdmin() || (request.auth.uid == resource.data.clientId);
    }

    // Invoices:
    // Clients can read their own invoices.
    // Admins can manage all invoices (create, update, delete).
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (request.auth.uid == resource.data.clientId);
      allow create, update, delete: if isAdmin();
    }

    // Reports: Admin managed
    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    // Activity Logs: 
    // Admins can read. Writes should ideally be from trusted server environments (e.g. Cloud Functions via Admin SDK)
    // or controlled admin actions. For simplicity here, admin write is allowed but secure carefully.
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      // Allow admin write, but for client-triggered logs, use a backend function.
      allow write: if isAdmin(); 
    }

    // Default deny for any other collection/path not explicitly matched above.
    // This is important for security.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
