rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return request.auth.token.email == "admin@saifmasr.com" || request.auth.token.email == "admin@example.com";
    }

    // System Settings
    match /systemSettings/{settingId} {
      allow read: if true; // Publicly readable for portal name
      allow write: if isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin(); // Admins can create clients
      // Clients can potentially read/update their own info if tied to auth.uid
      // allow read, update: if request.auth.uid == clientId; // Example if client ID is user UID
    }
    match /clients/{document=**} { // For listing
        allow list: if isAdmin();
    }


    // Services
    match /services/{serviceId} {
      allow read: if request.auth != null; // Authenticated users can read services
      allow create, update, delete: if isAdmin();
    }
     match /services/{document=**} { // For listing
        allow list: if request.auth != null;
    }

    // Service Requests
    match /serviceRequests/{requestId} {
      allow read, update: if isAdmin() || request.auth.uid == resource.data.clientId;
      allow create: if request.auth.uid == request.resource.data.clientId; // User can only create for themselves
      allow delete: if isAdmin();
    }
    match /serviceRequests/{document=**} { // For listing
        allow list: if isAdmin(); // Admins can list all
        // Clients might list their own using queries, rule would be on the query
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.clientId;
      allow create, update, delete: if isAdmin();
    }
     match /invoices/{document=**} { // For listing
        allow list: if isAdmin();
        // Clients might list their own using queries
    }

    // Employees
    match /employees/{employeeId} {
        allow read, create, update, delete: if isAdmin();
    }
    match /employees/{document=**} {
        allow list: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
        allow read, create, update, delete: if isAdmin();
    }
    match /reports/{document=**} {
        allow list: if isAdmin();
    }

    // Activity Logs
    match /activityLogs/{logId} {
      allow read: if isAdmin(); // Admins can read logs
      allow create: if request.auth != null; // Authenticated users can create logs
      // No update/delete for logs generally
    }
    match /activityLogs/{document=**} {
        allow list: if isAdmin();
    }

  }
}
