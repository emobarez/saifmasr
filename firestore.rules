
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to the system settings document for the portal name
    match /systemSettings/general {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin'; // Only admins can write
    }

    // Clients:
    // - Can only read/write their own documents in 'clients' if authenticated.
    // - This rule is a placeholder, typically client documents might not be directly writable by clients themselves
    //   or might be managed via backend functions or more specific rules.
    // - For now, assuming admins manage clients.
    match /clients/{clientId} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
      // Example for client self-access if needed (adjust based on actual UID usage)
      // allow read, update: if request.auth != null && request.auth.uid == clientId;
    }

    // Services:
    // - Anyone can read services (for public listing).
    // - Only admins can create, update, delete services.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Service Requests:
    // - Clients can create their own service requests.
    // - Clients can read their own service requests.
    // - Admins can read/write all service requests.
    match /serviceRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.clientId == request.auth.uid;
      allow read: if request.auth != null && (request.auth.token.role == 'admin' || resource.data.clientId == request.auth.uid);
      allow update: if request.auth != null && request.auth.token.role == 'admin'; // Only admins can update (e.g., status)
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Invoices:
    // - Clients can read their own invoices.
    // - Admins can read/write all invoices.
    match /invoices/{invoiceId} {
      allow create: if request.auth != null && request.auth.token.role == 'admin'; // Admins create invoices
      allow read: if request.auth != null && (request.auth.token.role == 'admin' || resource.data.clientId == request.auth.uid);
      allow update, delete: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Reports:
    // - Only admins can read/write reports.
    match /reports/{reportId} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Employees:
    // - Only admins can read/write employee data.
    match /employees/{employeeId} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // Activity Logs:
    // - Only admins can read activity logs.
    // - Backend (or trusted admin clients) should write activity logs. For simplicity, allow admin write here.
    match /activityLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Function to check user role (example, assuming role is stored in custom claims)
    // You would need to set these custom claims on your users via Firebase Admin SDK
    // For this app, role is determined client-side based on email for simplicity,
    // but for true security, custom claims are preferred for rules.
    // function isAdmin() {
    //   return request.auth.token.role == 'admin';
    // }
    // function isClient() {
    //  return request.auth.token.role == 'client';
    // }
  }
}
