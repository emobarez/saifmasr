
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth.uid != null && (
        request.auth.token.email == 'admin@saifmasr.com' ||
        request.auth.token.email == 'admin@example.com' // For testing/development
      );
    }

    // Clients collection
    match /clients/{clientId} {
      // Admins can read and write any client document
      allow read, write: if isAdmin();
      // Authenticated users can read their own client document
      allow get: if request.auth.uid == clientId;
      // Allow client creation if user is authenticated (typically during signup)
      // More specific rules might be needed if creation is restricted
      allow create: if request.auth.uid != null;
      // Clients can update their own document (e.g. profile updates)
      allow update: if request.auth.uid == clientId;
    }

    // Services collection
    match /services/{serviceId} {
      // Admins can create, read, update, delete services
      allow read, write: if isAdmin();
      // Clients can read services (e.g., to display on a public page or in their portal)
      allow get, list: if request.auth.uid != null;
    }

    // Service Requests collection
    match /serviceRequests/{requestId} {
      // Admins can read and update any service request
      allow read, update: if isAdmin();
      // Authenticated users can create service requests for themselves
      allow create: if request.auth.uid == request.resource.data.clientId;
      // Authenticated users can read their own service requests
      allow get, list: if request.auth.uid == resource.data.clientId;
    }

    // System Settings collection
    match /systemSettings/{settingId} {
      // Admins can read and write system settings
      allow read, write: if isAdmin();
      // Authenticated users can read system settings (e.g. for portalName)
      allow get: if request.auth.uid != null;
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      // Admins can read and write any invoice
      allow read, write: if isAdmin();

      // Clients can read (get, list) their own invoices
      allow get, list: if request.auth.uid == resource.data.clientId && request.auth.uid != null;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
