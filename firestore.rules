rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth.token.email == "admin@saifmasr.com" || request.auth.token.email == "admin@example.com";
    }

    // Clients: Admins can manage all, clients can only manage their own.
    match /clients/{clientId} {
      allow read, write: if isAdmin();
      allow read, update: if request.auth.uid == clientId;
    }

    // Services: Admins can manage, all authenticated users can read.
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /services/{serviceId}/faqs/{faqId} {
       allow read: if request.auth != null;
       allow write: if isAdmin(); // Or more specific if needed
    }

    // Service Requests:
    // Admins can read all and update status.
    // Clients can create for themselves and read their own.
    match /serviceRequests/{requestId} {
      allow read, update: if isAdmin();
      allow create: if request.auth.uid == request.resource.data.clientId;
      allow read: if request.auth.uid == resource.data.clientId;
    }

    // Invoices:
    // Admins can manage all.
    // Clients can read their own.
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
      allow read: if request.auth.uid == resource.data.clientId;
    }

    // System Settings: Only admins can read/write
    match /systemSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Employees: Only admins can manage employees
    match /employees/{employeeId} {
      allow read, write, create, update, delete: if isAdmin();
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
